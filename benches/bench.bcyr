include "lib/syscalls.cyr"
include "lib/string.cyr"
include "lib/alloc.cyr"
include "lib/fmt.cyr"
include "lib/str.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/tagged.cyr"
include "lib/fnptr.cyr"
include "lib/trait.cyr"
include "lib/bench.cyr"
include "src/error.cyr"
include "src/types.cyr"
include "src/agent.cyr"
include "src/security.cyr"
include "src/telemetry.cyr"
include "src/audit.cyr"
include "src/llm.cyr"
include "src/secrets.cyr"
include "src/config.cyr"
include "src/classification.cyr"
include "src/validation.cyr"
include "src/hardware.cyr"
fn _b_agent_id_new() { agent_id_new(); return 0; }
fn _b_trace_context_new() { trace_context_new(); return 0; }
var _bench_parent = 0;
fn _b_trace_context_child() { tctx_child(_bench_parent); return 0; }
fn _b_sandbox_config() { sandbox_config_new(); return 0; }
fn _b_agent_id_to_str() { agent_id_to_str(agent_id_new()); return 0; }
fn _b_agent_id_roundtrip() { agent_id_from_str(agent_id_to_str(agent_id_new())); return 0; }
fn _b_version_to_str() { version_to_str(version_new(0, 90, 0)); return 0; }
var _bench_vs = 0;
fn _b_version_roundtrip() { version_to_str(payload(version_from_str(_bench_vs))); return 0; }
fn _b_traceparent() { tctx_to_traceparent(trace_context_new()); return 0; }
fn _b_inference_request() {
    var r = inference_request_new(str_from("llama3"));
    ireq_set_max_tokens(r, 1024);
    vec_push(ireq_messages(r), message_text(ROLE_USER, str_from("hello")));
    return 0;
}
fn _b_audit_entry() {
    audit_entry_new(str_from("e1"), agent_id_new(), str_from("read"), AUDIT_INFO);
    return 0;
}
fn _b_accel_device() {
    var d = accelerator_device_new(0, str_from("RTX 4090"), VENDOR_NVIDIA, DEV_GPU);
    adev_set_vram_total(d, 24576);
    return 0;
}
fn _b_token_usage() {
    var u = token_usage_new();
    tusage_set_prompt(u, 100);
    tusage_set_completion(u, 50);
    tusage_set_total(u, 150);
    return 0;
}
fn _b_security_context() {
    var ctx = security_context_new(agent_id_new());
    vec_push(secctx_permissions(ctx), PERM_FILE_READ);
    vec_push(secctx_permissions(ctx), PERM_NETWORK_ACCESS);
    return 0;
}
fn _b_message_build() {
    message_text(ROLE_SYSTEM, str_from("You are helpful."));
    message_text(ROLE_USER, str_from("What is Cyrius?"));
    message_text(ROLE_ASSISTANT, str_from("A systems language."));
    return 0;
}
# --- serde benchmark helpers ---
fn _ser(ptr, fn_ptr) {
    var sb = str_builder_new();
    fncall2(fn_ptr, ptr, sb);
    return str_builder_build(sb);
}
var _bench_rl_json = 0;
var _bench_tu_json = 0;
var _bench_af_json = 0;
var _bench_is_json = 0;
var _bench_as_json = 0;
fn _b_rl_to_json() { _ser(resource_limits_new(), &ResourceLimits_to_json); return 0; }
fn _b_rl_from_json() { ResourceLimits_from_json(_bench_rl_json); return 0; }
fn _b_tu_to_json() {
    var u = token_usage_new();
    tusage_set_prompt(u, 100);
    tusage_set_completion(u, 50);
    tusage_set_total(u, 150);
    _ser(u, &TokenUsage_to_json);
    return 0;
}
fn _b_tu_from_json() { TokenUsage_from_json(_bench_tu_json); return 0; }
fn _b_af_to_json() {
    var f = accelerator_flags_new();
    aflags_set_cuda(f, 1);
    aflags_set_vulkan(f, 1);
    _ser(f, &AcceleratorFlags_to_json);
    return 0;
}
fn _b_af_from_json() { AcceleratorFlags_from_json(_bench_af_json); return 0; }
fn _b_is_to_json() {
    var s = injection_scores_new();
    store64(s, 85);
    store64(s + 8, 10);
    store64(s + 32, 95);
    _ser(s, &InjectionScores_to_json);
    return 0;
}
fn _b_is_from_json() { InjectionScores_from_json(_bench_is_json); return 0; }
fn _b_as_to_json() {
    var s = agent_stats_new();
    store64(s, 999);
    store64(s + 8, 50000);
    store64(s + 16, 86400);
    _ser(s, &AgentStats_to_json);
    return 0;
}
fn _b_as_from_json() { AgentStats_from_json(_bench_as_json); return 0; }

fn tier(label) {
    syscall(SYS_WRITE, 1, "\n", 1);
    syscall(SYS_WRITE, 1, label, strlen(label));
    syscall(SYS_WRITE, 1, "\n", 1);
    return 0;
}
fn run(bname, fp, batch, rounds) {
    var b = bench_new(bname);
    bench_run_batch(b, fp, batch, rounds);
    bench_report(b);
    return 0;
}
fn main() {
    alloc_init();
    _bench_parent = trace_context_new();
    _bench_vs = str_from("0.90.0");
    println("=== agnostik benchmarks (Cyrius v3.2.5) ===");
    tier("[tier1] core");
    run("agent_id_new", &_b_agent_id_new, 1000, 10);
    run("trace_context_new", &_b_trace_context_new, 1000, 10);
    run("trace_context_child", &_b_trace_context_child, 1000, 10);
    run("sandbox_config_default", &_b_sandbox_config, 1000, 10);
    tier("[tier2] format");
    run("agent_id_to_str", &_b_agent_id_to_str, 1000, 10);
    run("agent_id_roundtrip", &_b_agent_id_roundtrip, 1000, 10);
    run("version_to_str", &_b_version_to_str, 1000, 10);
    run("version_roundtrip", &_b_version_roundtrip, 1000, 10);
    run("traceparent_format", &_b_traceparent, 500, 10);
    tier("[tier3] integration");
    run("inference_request_full", &_b_inference_request, 500, 10);
    run("audit_entry_full", &_b_audit_entry, 500, 10);
    run("accelerator_device_full", &_b_accel_device, 500, 10);
    run("security_context_full", &_b_security_context, 500, 10);
    run("message_build_3turn", &_b_message_build, 500, 10);
    run("token_usage_update", &_b_token_usage, 1000, 10);
    # Pre-generate JSON for from_json benchmarks
    _bench_rl_json = _ser(resource_limits_new(), &ResourceLimits_to_json);
    var _tu = token_usage_new();
    tusage_set_prompt(_tu, 100); tusage_set_completion(_tu, 50); tusage_set_total(_tu, 150);
    _bench_tu_json = _ser(_tu, &TokenUsage_to_json);
    var _af = accelerator_flags_new();
    aflags_set_cuda(_af, 1); aflags_set_vulkan(_af, 1);
    _bench_af_json = _ser(_af, &AcceleratorFlags_to_json);
    var _is = injection_scores_new();
    store64(_is, 85); store64(_is + 8, 10); store64(_is + 32, 95);
    _bench_is_json = _ser(_is, &InjectionScores_to_json);
    var _as = agent_stats_new();
    store64(_as, 999); store64(_as + 8, 50000); store64(_as + 16, 86400);
    _bench_as_json = _ser(_as, &AgentStats_to_json);
    tier("[tier4] serde");
    run("resource_limits_to_json", &_b_rl_to_json, 500, 10);
    run("resource_limits_from_json", &_b_rl_from_json, 500, 10);
    run("token_usage_to_json", &_b_tu_to_json, 500, 10);
    run("token_usage_from_json", &_b_tu_from_json, 500, 10);
    run("accel_flags_to_json", &_b_af_to_json, 500, 10);
    run("accel_flags_from_json", &_b_af_from_json, 500, 10);
    run("injection_scores_to_json", &_b_is_to_json, 500, 10);
    run("injection_scores_from_json", &_b_is_from_json, 500, 10);
    run("agent_stats_to_json", &_b_as_to_json, 500, 10);
    run("agent_stats_from_json", &_b_as_from_json, 500, 10);
    println("\n=== done ===");
    return 0;
}
var r = main();
syscall(SYS_EXIT, r);
