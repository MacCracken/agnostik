fn mcap_supports_structured(m) { return load64(m + 56); }
fn mcap_supports_streaming(m)  { return load64(m + 64); }
fn mcap_supports_thinking(m)   { return load64(m + 72); }
fn mcap_supports_audio(m)      { return load64(m + 80); }
fn mcap_supports_citations(m)  { return load64(m + 88); }
fn mcap_set_display_name(m, v)    { store64(m + 8, v); return 0; }
fn mcap_set_context_window(m, v)  { store64(m + 24, v); return 0; }
fn mcap_set_max_output(m, v)      { store64(m + 32, v); return 0; }
