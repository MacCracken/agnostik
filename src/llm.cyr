enum LlmProvider { LLM_OLLAMA; LLM_OPENAI; LLM_ANTHROPIC; LLM_GOOGLE; LLM_DEEPSEEK; LLM_CUSTOM; }
fn llm_provider_name(p) {
    if (p == LLM_OLLAMA)    { return "Ollama"; }
    if (p == LLM_OPENAI)    { return "OpenAI"; }
    if (p == LLM_ANTHROPIC) { return "Anthropic"; }
    if (p == LLM_GOOGLE)    { return "Google"; }
    if (p == LLM_DEEPSEEK)  { return "DeepSeek"; }
    return "Custom";
}
enum MessageRole { ROLE_SYSTEM; ROLE_USER; ROLE_ASSISTANT; ROLE_TOOL; }
enum ContentBlockType { CB_TEXT; CB_IMAGE; CB_TOOL_USE; CB_TOOL_RESULT; CB_THINKING; }
fn content_text(text) { return tagged_new(CB_TEXT, text); }
fn content_tool_use(tid, tname, targs) {
    var tu = alloc(24);
    store64(tu, tid);
    store64(tu + 8, tname);
    store64(tu + 16, targs);
    return tagged_new(CB_TOOL_USE, tu);
}
fn content_thinking(text) { return tagged_new(CB_THINKING, text); }
fn content_block_type(cb)    { return tag(cb); }
fn content_block_payload(cb) { return payload(cb); }
enum FinishReason { FINISH_STOP; FINISH_LENGTH; FINISH_CONTENT_FILTER; FINISH_TOOL_USE; FINISH_ERROR; }
enum ToolChoice { TOOL_AUTO; TOOL_NONE; TOOL_REQUIRED; }
fn message_new(role) {
    var m = alloc(24);
    store64(m, role);
    store64(m + 8, vec_new());
    store64(m + 16, 0);
    return m;
}
fn message_text(role, text) {
    var m = message_new(role);
    vec_push(load64(m + 8), content_text(text));
    return m;
}
fn msg_role(m)    { return load64(m); }
fn msg_content(m) { return load64(m + 8); }
fn tool_definition_new(tname, desc, params) {
    var t = alloc(32);
    store64(t, tname);
    store64(t + 8, desc);
    store64(t + 16, params);
    store64(t + 24, 0);
    return t;
}
fn tooldef_name(t) { return load64(t); }
fn tool_call_new(tid, tname, targs) {
    var tc = alloc(24);
    store64(tc, tid);
    store64(tc + 8, tname);
    store64(tc + 16, targs);
    return tc;
}
fn sampling_params_new() {
    var s = alloc(56);
    store64(s, 1000);
    var i = 8;
    while (i < 48) { store64(s + i, 0); i = i + 8; }
    store64(s + 40, vec_new());
    return s;
}
fn samp_temperature(s) { return load64(s); }
fn samp_set_temperature(s, v) { store64(s, v); return 0; }
fn token_usage_new() {
    var u = alloc(40);
    var i = 0;
    while (i < 40) { store64(u + i, 0); i = i + 8; }
    return u;
}
fn tusage_prompt(u)      { return load64(u); }
fn tusage_completion(u)  { return load64(u + 8); }
fn tusage_total(u)       { return load64(u + 16); }
fn tusage_set_prompt(u, v)     { store64(u, v); return 0; }
fn tusage_set_completion(u, v) { store64(u + 8, v); return 0; }
fn tusage_set_total(u, v)      { store64(u + 16, v); return 0; }
fn inference_request_new(model) {
    var r = alloc(80);
    store64(r, model);
    store64(r + 8, str_from(""));
    store64(r + 16, 0);
    store64(r + 24, vec_new());
    store64(r + 32, 0);
    store64(r + 40, sampling_params_new());
    store64(r + 48, 0);
    store64(r + 56, vec_new());
    store64(r + 64, 0);
    store64(r + 72, 0);
    return r;
}
fn ireq_model(r)         { return load64(r); }
fn ireq_messages(r)      { return load64(r + 24); }
fn ireq_max_tokens(r)    { return load64(r + 32); }
fn ireq_sampling(r)      { return load64(r + 40); }
fn ireq_stream(r)        { return load64(r + 48); }
fn ireq_tools(r)         { return load64(r + 56); }
fn ireq_set_system(r, v)     { store64(r + 16, v); return 0; }
fn ireq_set_max_tokens(r, v) { store64(r + 32, v); return 0; }
fn ireq_set_stream(r, v)     { store64(r + 48, v); return 0; }
fn inference_response_new(model) {
    var r = alloc(48);
    store64(r, 0);
    store64(r + 8, model);
    store64(r + 16, vec_new());
    store64(r + 24, token_usage_new());
    store64(r + 32, FINISH_STOP);
    store64(r + 40, vec_new());
    return r;
}
fn iresp_model(r)          { return load64(r + 8); }
fn iresp_content(r)        { return load64(r + 16); }
fn iresp_usage(r)          { return load64(r + 24); }
fn iresp_finish_reason(r)  { return load64(r + 32); }
fn iresp_tool_calls(r)     { return load64(r + 40); }
fn iresp_set_finish_reason(r, v) { store64(r + 32, v); return 0; }
fn rate_limit_info_new() {
    var r = alloc(40);
    var i = 0;
    while (i < 40) { store64(r + i, 0); i = i + 8; }
    return r;
}
