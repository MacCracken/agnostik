# security.cyr — sandbox, permissions, RBAC, capabilities
#
# Ports: Permission, FsAccess, NetworkAccess, SeccompAction,
#        SandboxConfig, SecurityContext, SecurityPolicy,
#        LinuxCapability, Role, CgroupLimits, NamespaceConfig, etc.

# ================================================================
# Permission enum
# ================================================================

enum Permission {
    PERM_FILE_READ;
    PERM_FILE_WRITE;
    PERM_NETWORK_ACCESS;
    PERM_PROCESS_SPAWN;
    PERM_LLM_INFERENCE;
    PERM_AUDIT_READ;
}

# ================================================================
# FsAccess enum
# ================================================================

enum FsAccess {
    FS_NO_ACCESS;
    FS_READ_ONLY;
    FS_READ_WRITE;
}

# ================================================================
# NetworkAccess enum
# ================================================================

enum NetworkAccess {
    NET_NONE;
    NET_LOCALHOST_ONLY;
    NET_RESTRICTED;
    NET_FULL;
}

# ================================================================
# SeccompAction enum
# ================================================================

enum SeccompAction {
    SECCOMP_ALLOW;
    SECCOMP_KILL;
    SECCOMP_KILL_PROCESS;
    SECCOMP_TRAP;
    SECCOMP_LOG;
    SECCOMP_NOTIFY;
}

# Errno and Trace carry a value — use tagged union
fn seccomp_errno(errno_val) { return tagged_new(100, errno_val); }
fn seccomp_trace(trace_val) { return tagged_new(101, trace_val); }

# ================================================================
# SeccompArgOp enum
# ================================================================

enum SeccompArgOp {
    ARG_NOT_EQUAL;
    ARG_LESS_THAN;
    ARG_LESS_EQUAL;
    ARG_EQUAL;
    ARG_GREATER_EQUAL;
    ARG_GREATER_THAN;
    ARG_MASKED_EQUAL;
}

# ================================================================
# SeccompArch enum
# ================================================================

