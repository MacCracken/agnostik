var TEXTMAP_GET = 0;
var TEXTMAP_SET = 1;
fn textmap_carrier_vtable(get_fn, set_fn) {
    var vt = alloc(16);
    store64(vt, get_fn);
    store64(vt + 8, set_fn);
    return vt;
}
fn textmap_carrier_new(vtable, data) { return trait_obj_new(vtable, data); }
fn textmap_get(carrier, key) { return trait_call1(carrier, TEXTMAP_GET, key); }
var _textmap_extra = 0;
fn textmap_set(carrier, key, value) {
    _textmap_extra = value;
    return trait_call1(carrier, TEXTMAP_SET, key);
}
var PROPAGATOR_INJECT = 0;
var PROPAGATOR_EXTRACT = 1;
fn textmap_propagator_vtable(inject_fn, extract_fn) {
    var vt = alloc(16);
    store64(vt, inject_fn);
    store64(vt + 8, extract_fn);
    return vt;
}
fn propagator_new(vtable, data) { return trait_obj_new(vtable, data); }
var _propagator_extra = 0;
fn propagator_inject(prop, context, carrier) {
    _propagator_extra = carrier;
    return trait_call1(prop, PROPAGATOR_INJECT, context);
}
fn propagator_extract(prop, carrier) {
    return trait_call1(prop, PROPAGATOR_EXTRACT, carrier);
}
var SC_EXPORT = 0;
var SC_FLUSH = 1;
var SC_SHUTDOWN = 2;
fn span_collector_vtable(export_fn, flush_fn, shutdown_fn) {
    var vt = alloc(24);
    store64(vt, export_fn);
    store64(vt + 8, flush_fn);
    store64(vt + 16, shutdown_fn);
    return vt;
}
fn span_collector_new(vtable, data) { return trait_obj_new(vtable, data); }
fn sc_export(collector, spans)  { return trait_call1(collector, SC_EXPORT, spans); }
fn sc_flush(collector)          { return trait_call0(collector, SC_FLUSH); }
fn sc_shutdown(collector)       { return trait_call0(collector, SC_SHUTDOWN); }
