# CSPRNG — fills `n` bytes at `buf` with kernel-supplied randomness.
# Audit 2026-04-26 F-001: removed xorshift state and the deterministic
# fallback constant. UUIDs now draw fresh entropy per call.
fn _fill_random(buf, n) {
    # Primary: getrandom(2) — syscall 318 on x86_64. Preferred over
    # opening /dev/urandom because it works in sandboxed envs that
    # block file IO and never returns short reads for buffers <= 256 B.
    var got = syscall(318, buf, n, 0);
    if (got == n) { return 0; }
    # Fallback: /dev/urandom for older kernels / restricted seccomp.
    var fd = syscall(2, "/dev/urandom", 0, 0);
    if (fd >= 0) {
        # Loop in case the kernel returns a short read (rare for small n
        # but legal per read(2)).
        var off = 0;
        while (off < n) {
            var r = syscall(0, fd, buf + off, n - off);
            if (r <= 0) { off = 0 - 1; }
            else { off = off + r; }
        }
        syscall(3, fd);
        if (off == n) { return 0; }
    }
    # Both sources failed. Identifier generation is security-critical
    # (agent_id, session_id, trace_id back authorisation in aegis/sigil)
    # so we fail loudly rather than degrade to a deterministic seed.
    syscall(1, 2, "agnostik: CSPRNG unavailable (getrandom + /dev/urandom both failed)\n", 67);
    syscall(60, 70);
    return 0 - 1;
}
fn agent_id_new() {
    var id = alloc(16);
    _fill_random(id, 16);
    # RFC 4122 v4 markers: high nibble of byte 6 = 0100, top two bits
    # of byte 8 = 10.
    var b6 = load8(id + 6);
    b6 = (b6 & 0x0F) | 0x40;
    store8(id + 6, b6);
    var b8 = load8(id + 8);
    b8 = (b8 & 0x3F) | 0x80;
    store8(id + 8, b8);
    return id;
}
fn agent_id_high(id) { return load64(id); }
fn agent_id_low(id)  { return load64(id + 8); }
fn agent_id_eq(a, b) {
    if (load64(a) != load64(b)) { return 0; }
    if (load64(a + 8) != load64(b + 8)) { return 0; }
    return 1;
}
var _hex_lut = "0123456789abcdef";
fn _hex_byte(buf, offset, byte) {
    store8(buf + offset, load8(_hex_lut + (byte >> 4)));
    store8(buf + offset + 1, load8(_hex_lut + (byte & 0x0F)));
    return 0;
}
fn agent_id_to_str(id) {
    # UUID format: 8-4-4-4-12 = 36 chars
    var buf = alloc(37);
    var pos = 0;
    var i = 0;
    while (i < 16) {
        if (i == 4) { store8(buf + pos, 45); pos = pos + 1; }
        if (i == 6) { store8(buf + pos, 45); pos = pos + 1; }
        if (i == 8) { store8(buf + pos, 45); pos = pos + 1; }
        if (i == 10) { store8(buf + pos, 45); pos = pos + 1; }
        _hex_byte(buf, pos, load8(id + i));
        pos = pos + 2;
        i = i + 1;
    }
    store8(buf + pos, 0);
    return str_new(buf, 36);
}
fn agent_id_from_str(s) {
    var data = str_data(s);
    var slen = str_len(s);
    if (slen != 36) { return err_invalid_argument(str_from("invalid agent id: expected UUID")); }
    var id = alloc(16);
    var si = 0;
    var bi = 0;
    while (bi < 16) {
        # Skip dashes
        if (si == 8) { si = si + 1; }
        if (si == 13) { si = si + 1; }
        if (si == 18) { si = si + 1; }
        if (si == 23) { si = si + 1; }
        var hi = load8(data + si);
        var lo = load8(data + si + 1);
        # Convert hex char → nibble
        if (hi >= 48 && hi <= 57) { hi = hi - 48; }
        elif (hi >= 97 && hi <= 102) { hi = hi - 87; }
        elif (hi >= 65 && hi <= 70) { hi = hi - 55; }
        else { return err_invalid_argument(str_from("invalid hex in agent id")); }
        if (lo >= 48 && lo <= 57) { lo = lo - 48; }
        elif (lo >= 97 && lo <= 102) { lo = lo - 87; }
        elif (lo >= 65 && lo <= 70) { lo = lo - 55; }
        else { return err_invalid_argument(str_from("invalid hex in agent id")); }
        store8(id + bi, hi << 4 | lo);
        si = si + 2;
        bi = bi + 1;
    }
    return Ok(id);
}
# --- JSON field extractors ------------------------------------------------
# Audit 2026-04-26 F-004: a strstr probe for `"key":` was matching the
# needle when it appeared *inside* a string value, e.g. an attacker-
# controlled `"note":"max_memory:..."` poisoned a sibling lookup for
# `max_memory`. The walker now tracks string boundaries and only
# matches when the cursor is outside `"..."`. Backslash escapes inside
# strings respected so `"\""` doesn't end the string early (parallels
# the F-002 fix in `_json_str`).
fn _json_find_value(src, key) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "\"");
    str_builder_add(sb, key);
    str_builder_add_cstr(sb, "\":");
    var needle = str_builder_build(sb);
    var nd = str_data(needle);
    var nlen = str_len(needle);
    var data = str_data(src);
    var slen = str_len(src);
    var i = 0;
    var in_str = 0;
    while (i + nlen <= slen) {
        var ch = load8(data + i);
        if (in_str == 1) {
            if (ch == 92 && i + 1 < slen) { i = i + 2; }
            elif (ch == 34) { in_str = 0; i = i + 1; }
            else { i = i + 1; }
        } else {
            if (ch == 34) {
                # Possible start of a string OR start of our needle.
                # If the next nlen bytes match the needle, treat as a
                # match (top-level key). Else enter string mode.
                if (memeq(data + i, nd, nlen) == 1) {
                    var vi = i + nlen;
                    # F-010: skip RFC 7159 whitespace (space, tab, LF, CR).
                    var skipping = 1;
                    while (vi < slen && skipping == 1) {
                        var w = load8(data + vi);
                        if (w == 32 || w == 9 || w == 10 || w == 13) { vi = vi + 1; }
                        else { skipping = 0; }
                    }
                    return vi;
                }
                in_str = 1;
                i = i + 1;
            } else { i = i + 1; }
        }
    }
    return 0 - 1;
}
# Audit 2026-04-26 F-003: handle leading '-' for negatives.
# Audit 2026-04-26 F-008: pre-multiply overflow check; we no longer
# accept digits whose multiply would lift val above i64::MAX. The
# original 19-digit cap was insufficient — values in
# [9223372036854775808, 9999999999999999999] still overflowed and
# wrapped silently. Both findings together close
# GHSA-72HV-8253-57QQ-shape risk.
fn _json_int(src, key) {
    var vi = _json_find_value(src, key);
    if (vi < 0) { return 0; }
    var data = str_data(src);
    var slen = str_len(src);
    var neg = 0;
    if (vi < slen && load8(data + vi) == 45) { neg = 1; vi = vi + 1; }
    var val = 0;
    var parsing = 1;
    while (vi < slen && parsing == 1) {
        var ch = load8(data + vi);
        # F-008: detect i64 overflow before it wraps. i64::MAX =
        # 9223372036854775807 = 922337203685477580 * 10 + 7. Stop
        # accepting digits the moment the next multiply would lift val
        # above MAX; a 19-digit overflowing input like 9999999999999999999
        # used to wrap silently to a negative i64, letting an attacker
        # smuggle a value past `if (x > LIMIT)` non-negative guards.
        if (ch < 48 || ch > 57) { parsing = 0; }
        elif (val > 922337203685477580) { parsing = 0; }
        elif (val == 922337203685477580 && (ch - 48) > 7) { parsing = 0; }
        else {
            val = val * 10 + (ch - 48);
            vi = vi + 1;
        }
    }
    if (neg == 1) { return 0 - val; }
    return val;
}
# Audit 2026-04-26 F-002: respect '\' escape so `"abc\"xyz"` parses as
# the full string, not just the prefix. We decode the common escapes
# (\" \\ \/ \n \t \r \b \f) by writing into a fresh buffer; the buffer
# is at most as long as the source so allocating slen bytes is safe.
# `\uXXXX` is left as a known limitation — F-004 follow-up.
fn _json_str(src, key) {
    var vi = _json_find_value(src, key);
    if (vi < 0) { return 0; }
    var data = str_data(src);
    var slen = str_len(src);
    # F-009: gate the 4-byte memeq probe on remaining length so we
    # don't read past slen on truncated input like `{"x":nu}`.
    if (vi + 4 <= slen && memeq(data + vi, "null", 4) == 1) { return 0; }
    if (vi >= slen) { return 0; }
    if (load8(data + vi) != 34) { return 0; }
    vi = vi + 1;
    var out = alloc(slen + 1);
    var op = 0;
    var done = 0;
    while (vi < slen && done == 0) {
        var ch = load8(data + vi);
        if (ch == 34) { done = 1; }
        elif (ch == 92 && vi + 1 < slen) {
            var esc = load8(data + vi + 1);
            if (esc == 34)      { store8(out + op, 34); op = op + 1; }
            elif (esc == 92)    { store8(out + op, 92); op = op + 1; }
            elif (esc == 47)    { store8(out + op, 47); op = op + 1; }
            elif (esc == 110)   { store8(out + op, 10); op = op + 1; }
            elif (esc == 116)   { store8(out + op, 9);  op = op + 1; }
            elif (esc == 114)   { store8(out + op, 13); op = op + 1; }
            elif (esc == 98)    { store8(out + op, 8);  op = op + 1; }
            elif (esc == 102)   { store8(out + op, 12); op = op + 1; }
            else { store8(out + op, 92); store8(out + op + 1, esc); op = op + 2; }
            vi = vi + 2;
        }
        else { store8(out + op, ch); op = op + 1; vi = vi + 1; }
    }
    return str_new(out, op);
}

fn user_id_new()              { return agent_id_new(); }
fn user_id_high(id)           { return agent_id_high(id); }
fn user_id_low(id)            { return agent_id_low(id); }
fn user_id_eq(a, b)           { return agent_id_eq(a, b); }
fn user_id_to_str(id)         { return agent_id_to_str(id); }
fn user_id_from_str(s)        { return agent_id_from_str(s); }
fn version_new(major, minor, patch) {
    var v = alloc(40);
    store64(v, major);
    store64(v + 8, minor);
    store64(v + 16, patch);
    store64(v + 24, 0);
    store64(v + 32, 0);
    return v;
}
fn version_default() { return version_new(0, 0, 0); }
fn version_major(v)      { return load64(v); }
fn version_minor(v)      { return load64(v + 8); }
fn version_patch(v)      { return load64(v + 16); }
fn version_prerelease(v) { return load64(v + 24); }
fn version_build(v)      { return load64(v + 32); }
fn version_set_prerelease(v, pre) { store64(v + 24, pre); return 0; }
fn version_set_build(v, b)        { store64(v + 32, b); return 0; }
fn version_to_str(v) {
    var buf = alloc(128);
    var cap = 127;
    var pos = 0;
    pos = pos + fmt_int_buf(version_major(v), buf + pos);
    store8(buf + pos, 46); pos = pos + 1;
    pos = pos + fmt_int_buf(version_minor(v), buf + pos);
    store8(buf + pos, 46); pos = pos + 1;
    pos = pos + fmt_int_buf(version_patch(v), buf + pos);
    var pre = version_prerelease(v);
    if (pre != 0) {
        var plen = str_len(pre);
        if (pos + 1 + plen < cap) {
            store8(buf + pos, 45); pos = pos + 1;
            memcpy(buf + pos, str_data(pre), plen);
            pos = pos + plen;
        }
    }
    var bld = version_build(v);
    if (bld != 0) {
        var blen = str_len(bld);
        if (pos + 1 + blen < cap) {
            store8(buf + pos, 43); pos = pos + 1;
            memcpy(buf + pos, str_data(bld), blen);
            pos = pos + blen;
        }
    }
    store8(buf + pos, 0);
    return str_new(buf, pos);
}
fn version_from_str(s) {
    var data = str_data(s);
    var slen = str_len(s);
    var v = alloc(40);
    store64(v, 0);
    store64(v + 8, 0);
    store64(v + 16, 0);
    store64(v + 24, 0);
    store64(v + 32, 0);
    # Find first dot
    var i = 0;
    var dot1 = 0 - 1;
    while (i < slen) {
        if (load8(data + i) == 46) { dot1 = i; break; }
        i = i + 1;
    }
    if (dot1 < 0) { return err_invalid_argument(str_from("invalid version: missing dot")); }
    # Find second dot
    i = dot1 + 1;
    var dot2 = 0 - 1;
    while (i < slen) {
        if (load8(data + i) == 46) { dot2 = i; break; }
        i = i + 1;
    }
    if (dot2 < 0) { return err_invalid_argument(str_from("invalid version: missing second dot")); }
    # Find pre-release (-) or build (+) separator
    # Use strchr to find hyphen or plus after patch
    var patch_end = slen;
    var hyph = strchr(data + dot2 + 1, 45);
    var plus = strchr(data + dot2 + 1, 43);
    if (hyph >= 0) { patch_end = dot2 + 1 + hyph; }
    elif (plus >= 0) { patch_end = dot2 + 1 + plus; }
    # Audit 2026-04-26 F-005: every segment must be wholly digits.
    # str_to_int silently returns 0 for non-numeric input, so a string
    # like "abc.1.2" used to parse as 0.1.2; now it errors.
    var maj_len = dot1;
    var min_len = dot2 - dot1 - 1;
    var pat_len = patch_end - dot2 - 1;
    if (maj_len == 0 || min_len == 0 || pat_len == 0) {
        return err_invalid_argument(str_from("invalid version: empty segment"));
    }
    var k = 0;
    while (k < maj_len) {
        var c = load8(data + k);
        if (c < 48 || c > 57) {
            return err_invalid_argument(str_from("invalid version: non-digit in major"));
        }
        k = k + 1;
    }
    k = 0;
    while (k < min_len) {
        var c = load8(data + dot1 + 1 + k);
        if (c < 48 || c > 57) {
            return err_invalid_argument(str_from("invalid version: non-digit in minor"));
        }
        k = k + 1;
    }
    k = 0;
    while (k < pat_len) {
        var c = load8(data + dot2 + 1 + k);
        if (c < 48 || c > 57) {
            return err_invalid_argument(str_from("invalid version: non-digit in patch"));
        }
        k = k + 1;
    }
    var major_s = str_new(data, maj_len);
    store64(v, str_to_int(major_s));
    var minor_s = str_new(data + dot1 + 1, min_len);
    store64(v + 8, str_to_int(minor_s));
    var patch_s = str_new(data + dot2 + 1, pat_len);
    store64(v + 16, str_to_int(patch_s));
    # Parse prerelease and build if present
    if (patch_end < slen) {
        var sep = load8(data + patch_end);
        if (sep == 45) {
            # Pre-release: find +build if any
            var build_start = slen;
            i = patch_end + 1;
            while (i < slen) {
                if (load8(data + i) == 43) { build_start = i; break; }
                i = i + 1;
            }
            var pre = str_new(data + patch_end + 1, build_start - patch_end - 1);
            store64(v + 24, pre);
            if (build_start < slen) {
                var bld = str_new(data + build_start + 1, slen - build_start - 1);
                store64(v + 32, bld);
            }
        }
        elif (sep == 43) {
            var bld = str_new(data + patch_end + 1, slen - patch_end - 1);
            store64(v + 32, bld);
        }
    }
    return Ok(v);
}
fn version_eq(a, b) {
    if (version_major(a) != version_major(b)) { return 0; }
    if (version_minor(a) != version_minor(b)) { return 0; }
    if (version_patch(a) != version_patch(b)) { return 0; }
    return 1;
}
enum MessageType {
    MSG_COMMAND;
    MSG_RESPONSE;
    MSG_EVENT;
    MSG_HEARTBEAT;
}
enum SystemStatus {
    STATUS_HEALTHY;
    STATUS_DEGRADED;
    STATUS_CRITICAL;
    STATUS_UNKNOWN;
}
fn capabilities_new() {
    var c = alloc(32);
    store64(c, 0);
    store64(c + 8, 0);
    store64(c + 16, 0);
    store64(c + 24, 0);
    return c;
}
fn capabilities_llm(c)            { return load64(c); }
fn capabilities_virtualization(c) { return load64(c + 8); }
fn capabilities_gpu(c)            { return load64(c + 16); }
fn capabilities_tpm(c)            { return load64(c + 24); }
fn capabilities_set_llm(c, v)            { store64(c, v); return 0; }
fn capabilities_set_virtualization(c, v) { store64(c + 8, v); return 0; }
fn capabilities_set_gpu(c, v)            { store64(c + 16, v); return 0; }
fn capabilities_set_tpm(c, v)            { store64(c + 24, v); return 0; }
fn capabilities_eq(a, b) {
    if (load64(a) != load64(b)) { return 0; }
    if (load64(a + 8) != load64(b + 8)) { return 0; }
    if (load64(a + 16) != load64(b + 16)) { return 0; }
    if (load64(a + 24) != load64(b + 24)) { return 0; }
    return 1;
}
fn component_config_new(name, enabled) {
    var c = alloc(24);
    store64(c, name);
    store64(c + 8, enabled);
    store64(c + 16, map_new());
    return c;
}
fn component_config_name(c)     { return load64(c); }
fn component_config_enabled(c)  { return load64(c + 8); }
fn component_config_settings(c) { return load64(c + 16); }

fn message_type_name(t) {
    if (t == MSG_COMMAND)        { return "Command"; }
    elif (t == MSG_RESPONSE)     { return "Response"; }
    elif (t == MSG_EVENT)        { return "Event"; }
    elif (t == MSG_HEARTBEAT)    { return "Heartbeat"; }
    return "Unknown";
}
fn system_status_name(s) {
    if (s == STATUS_HEALTHY)     { return "Healthy"; }
    elif (s == STATUS_DEGRADED)  { return "Degraded"; }
    elif (s == STATUS_CRITICAL)  { return "Critical"; }
    return "Unknown";
}
