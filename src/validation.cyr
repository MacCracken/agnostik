enum ValidationSeverity {
    VSEV_LOW;
    VSEV_MEDIUM;
    VSEV_HIGH;
}
fn validation_severity_name(s) {
    if (s == VSEV_LOW)         { return "Low"; }
    elif (s == VSEV_MEDIUM)    { return "Medium"; }
    elif (s == VSEV_HIGH)      { return "High"; }
    return "Unknown";
}
fn validation_warning_new(code, message: Str, severity) {
    var w = alloc(40);
    store64(w, code);
    store64(w + 8, message);
    store64(w + 16, severity);
    store64(w + 24, 0);
    store64(w + 32, 0);
    return w;
}
fn vwarn_code(w)     { return load64(w); }
fn vwarn_message(w)  { return load64(w + 8); }
fn vwarn_severity(w) { return load64(w + 16); }
fn vwarn_position(w) { return load64(w + 24); }
fn vwarn_pattern(w)  { return load64(w + 32); }
# v1.1.1: widened to i8 (range 0..100 fits comfortably in i7).
# 40 B → 5 B per instance. Comments must live OUTSIDE the struct
# body — cyrius 5.10.14 derive codegen parses `#` inside the body
# as a field-name disruptor. Filed upstream; revisit when fixed.
#derive(Serialize)
struct InjectionScores {
    sql: i8; xss: i8; command: i8;
    path_traversal: i8; prompt_injection: i8;
}
fn injection_scores_new() {
    var s = alloc(5);
    var i = 0;
    while (i < 5) { store8(s + i, 0); i = i + 1; }
    return s;
}
fn iscore_sql(s)              { return load8(s); }
fn iscore_xss(s)              { return load8(s + 1); }
fn iscore_command(s)          { return load8(s + 2); }
fn iscore_path_traversal(s)   { return load8(s + 3); }
fn iscore_prompt_injection(s) { return load8(s + 4); }
# v1.1.1: explicit setters added so callers don't need raw store8.
fn iscore_set_sql(s, v)              { store8(s, v); return 0; }
fn iscore_set_xss(s, v)              { store8(s + 1, v); return 0; }
fn iscore_set_command(s, v)          { store8(s + 2, v); return 0; }
fn iscore_set_path_traversal(s, v)   { store8(s + 3, v); return 0; }
fn iscore_set_prompt_injection(s, v) { store8(s + 4, v); return 0; }
fn validation_result_new(valid, sanitized: Str) {
    var r = alloc(56);
    store64(r, valid);
    store64(r + 8, sanitized);
    store64(r + 16, vec_new());
    store64(r + 24, 0);
    store64(r + 32, 0);
    store64(r + 40, 0);
    store64(r + 48, 0);
    return r;
}
fn vresult_valid(r)            { return load64(r); }
fn vresult_sanitized(r)        { return load64(r + 8); }
fn vresult_warnings(r)         { return load64(r + 16); }
fn vresult_blocked(r)          { return load64(r + 24); }
fn vresult_block_reason(r)     { return load64(r + 32); }
fn vresult_injection_score(r)  { return load64(r + 40); }
fn vresult_injection_scores(r) { return load64(r + 48); }
fn vresult_set_blocked(r, reason: Str) {
    store64(r + 24, 1);
    store64(r + 32, reason);
    return 0;
}
